# syntax=docker/dockerfile:1.7

FROM oven/bun:1.3.10 AS tooling

# ---- Core tool versions (pinned) ---------------------------
ARG NODE_DEFAULT=24
ARG PNPM_VERSION=10.11.0
ARG NVM_VERSION=v0.40.3
ARG RTK_VERSION=0.30.0

WORKDIR /app

# ---- System packages ----------------------------------------
RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        bash \
        curl \
        git \
        ca-certificates \
        xz-utils \
        build-essential \
        zlib1g-dev \
        libssl-dev \
        libreadline-dev \
        libbz2-dev \
        libsqlite3-dev \
        gh \
        docker.io \
        wget \
        default-mysql-client \
        redis-tools \
        postgresql-client \
        jq \
    && rm -rf /var/lib/apt/lists/*

# ---- Runtime version managers -------------------------------
# Node.js manager: nvm
ENV NVM_DIR=/opt/nvm
ENV PNPM_HOME=/usr/local/pnpm
ENV PATH="${PNPM_HOME}:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin:/usr/local/bun-node-fallback-bin"
RUN mkdir -p "${NVM_DIR}" "${PNPM_HOME}" \
    && curl -fsSL "https://raw.githubusercontent.com/nvm-sh/nvm/${NVM_VERSION}/install.sh" | PROFILE=/dev/null NVM_DIR="${NVM_DIR}" bash \
    && bash -lc "set -e; export NVM_DIR=${NVM_DIR}; . ${NVM_DIR}/nvm.sh; nvm install ${NODE_DEFAULT}; nvm alias default ${NODE_DEFAULT}; nvm use default >/dev/null; npm install -g pnpm@${PNPM_VERSION} yarn @anthropic-ai/claude-code; ln -sf \"\$(command -v node)\" /usr/local/bin/node; ln -sf \"\$(command -v npm)\" /usr/local/bin/npm; ln -sf \"\$(command -v npx)\" /usr/local/bin/npx; ln -sf \"\$(command -v pnpm)\" /usr/local/bin/pnpm; ln -sf \"\$(command -v yarn)\" /usr/local/bin/yarn; ln -sf \"\$(command -v claude)\" /usr/local/bin/claude"

# Go manager: goenv
ENV GOENV_ROOT=/opt/goenv
ENV PATH="${GOENV_ROOT}/bin:${GOENV_ROOT}/shims:${PATH}"
RUN git clone https://github.com/go-nv/goenv.git "${GOENV_ROOT}"

# ---- Install workspace dependencies (layer cache) -----------
COPY package.json bun.lock ./
COPY cli/package.json ./cli/package.json
COPY shared/package.json ./shared/package.json
COPY hub/package.json ./hub/package.json
COPY web/package.json ./web/package.json
COPY website/package.json ./website/package.json
COPY docs/package.json ./docs/package.json

RUN --mount=type=cache,target=/root/.bun/install/cache \
    bun install --frozen-lockfile --production

COPY . .

# ---- Global CLI tools ----------------------------------------
RUN pnpm install -g mcp-swagger-server @mindfoldhq/trellis ux

# ---- RTK (Rust Token Killer) installation -------------------
RUN curl -fsSL "https://github.com/rtk-ai/rtk/releases/download/v${RTK_VERSION}/rtk-x86_64-unknown-linux-musl.tar.gz" \
    | tar -xz -C /usr/local/bin rtk \
    && chmod +x /usr/local/bin/rtk

# ---- Cleanup transient caches -------------------------------
RUN rm -rf /root/.cache /tmp/*

# ---- Download tunwg binary (Linux x64 only) -----------------
# Only download the specific binary needed for this build target
# Avoids dependency on other platform resource availability
RUN TUNWG_TARGET_PLATFORM=x64-linux bun run download:tunwg

# ---- Build zs executable (Linux x64) ------------------------
# Use existing build script to compile standalone executable
RUN cd /app/cli && bun run build:exe --target bun-linux-x64-baseline --outdir /tmp/zs-build

# Move the compiled binary to /usr/local/bin/zs
RUN mv /tmp/zs-build/bun-linux-x64-baseline/zs /usr/local/bin/zs && \
    chmod +x /usr/local/bin/zs && \
    rm -rf /tmp/zs-build

# ---- Runtime entrypoint and templates ------------------------
COPY docker/entrypoint.sh /usr/local/bin/docker-entrypoint.sh
COPY docker/claude-default /opt/zhushen/claude-default
RUN chmod +x /usr/local/bin/docker-entrypoint.sh


FROM oven/bun:1.3.10 AS runtime

WORKDIR /app

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        bash \
        bash-completion \
        curl \
        git \
        ca-certificates \
        xz-utils \
        openssh-client \
        gh \
        docker.io \
        wget \
        default-mysql-client \
        redis-tools \
        postgresql-client \
        jq \
        build-essential \
        zlib1g-dev \
        libssl-dev \
        libreadline-dev \
        libbz2-dev \
        libsqlite3-dev \
        python3 \
        procps \
        tree \
        rsync \
        less \
        vim-tiny \
        unzip \
        zip \
        file \
        dnsutils \
        iputils-ping \
        netcat-openbsd \
        lsof \
        psmisc \
        ripgrep \
        tmux \
    && rm -rf /var/lib/apt/lists/*

COPY --from=tooling /opt/nvm /opt/nvm
COPY --from=tooling /opt/goenv /opt/goenv
COPY --from=tooling /usr/local/pnpm /usr/local/pnpm
COPY --from=tooling /usr/local/bin /usr/local/bin
COPY --from=tooling /opt/zhushen/claude-default /opt/zhushen/claude-default
COPY docker/entrypoint.sh /usr/local/bin/docker-entrypoint.sh
RUN chmod +x /usr/local/bin/docker-entrypoint.sh

# ---- Default environment -------------------------------------
ENV NVM_DIR=/data/nvm
ENV NVM_SOURCE_DIR=/opt/nvm
ENV GOENV_ROOT=/data/goenv
ENV GOENV_SOURCE_DIR=/opt/goenv
ENV PNPM_HOME=/usr/local/pnpm
ENV PATH="${GOENV_ROOT}/bin:${GOENV_ROOT}/shims:${PNPM_HOME}:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"
ENV ZS_HOME=/data/runner
ENV ZS_API_URL=http://zs-hub:80
ENV ZS_GO_VERSION=1.24.3
ENV ZS_NODE_VERSION=24
ENV ZS_RUNNER_LOG_DESTINATION=stdio
ENV CLAUDE_TEMPLATE_DIR=/opt/zhushen/claude-default

ENTRYPOINT ["/usr/local/bin/docker-entrypoint.sh"]

# Foreground runner mode for containerized long-running service
CMD ["zs", "runner", "start-sync"]
